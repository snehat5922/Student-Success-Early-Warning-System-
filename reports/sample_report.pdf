from reportlab.platypus import (
    SimpleDocTemplate,
    Paragraph,
    Spacer,
    Table,
    TableStyle,
    PageBreak
)

from reportlab.lib import colors
from reportlab.lib.styles import getSampleStyleSheet

# Create PDF
pdf = SimpleDocTemplate(
    "reports/sample_report.pdf"
)

styles = getSampleStyleSheet()

elements = []

# Title
title = Paragraph(
    "Student Success & Early Warning System Report",
    styles["Title"]
)

elements.append(title)
elements.append(Spacer(1, 20))

# Introduction
intro = Paragraph(
    """
    This report provides an overview of student academic performance,
    attendance patterns, LMS engagement, assignment completion, and
    risk prediction generated by the Student Success & Early Warning System.
    """,
    styles["BodyText"]
)

elements.append(intro)
elements.append(Spacer(1, 20))

# Student Summary Table
data = [
    [
        "Student ID",
        "CGPA",
        "Attendance",
        "Risk Level"
    ],
    ["ST101", "8.2", "92%", "Low"],
    ["ST102", "6.5", "72%", "Medium"],
    ["ST103", "5.4", "55%", "High"],
    ["ST104", "9.0", "97%", "Low"],
    ["ST105", "4.8", "48%", "High"]
]

table = Table(data)

table.setStyle(
    TableStyle([
        ("BACKGROUND", (0, 0), (-1, 0), colors.darkblue),
        ("TEXTCOLOR", (0, 0), (-1, 0), colors.white),
        ("GRID", (0, 0), (-1, -1), 1, colors.black),
        ("ALIGN", (0, 0), (-1, -1), "CENTER"),
        ("FONTNAME", (0, 0), (-1, 0), "Helvetica-Bold"),
    ])
)

elements.append(
    Paragraph(
        "Student Performance Summary",
        styles["Heading2"]
    )
)

elements.append(table)
elements.append(Spacer(1, 20))

# Risk Analysis
risk_text = Paragraph(
    """
    <b>Risk Analysis:</b><br/><br/>

    High-risk students typically demonstrate:
    <br/>• Attendance below 60%
    <br/>• Low LMS engagement
    <br/>• Poor assignment completion
    <br/>• Quiz scores below average

    <br/><br/>

    The machine learning model predicts students who may require
    intervention before academic performance declines further.
    """,
    styles["BodyText"]
)

elements.append(risk_text)
elements.append(Spacer(1, 20))

# Recommendations
recommendations = Paragraph(
    """
    <b>Recommended Interventions</b>

    <br/><br/>

    • Attendance Counseling

    <br/>• Personalized Academic Mentoring

    <br/>• LMS Participation Encouragement

    <br/>• Quiz Revision Sessions

    <br/>• Parent/Faculty Notifications

    <br/>• Weekly Progress Monitoring
    """,
    styles["BodyText"]
)

elements.append(recommendations)

elements.append(PageBreak())

# Final Page
conclusion = Paragraph(
    """
    <b>Conclusion</b>

    <br/><br/>

    The Student Success & Early Warning System enables educational
    institutions to identify at-risk students early and take proactive
    measures to improve academic outcomes.

    By combining attendance, engagement, assessments, and machine
    learning predictions, institutions can significantly improve
    student retention and performance.
    """,
    styles["BodyText"]
)

elements.append(conclusion)

# Generate PDF
pdf.build(elements)

print("sample_report.pdf created successfully")
